PORT=5000
MONGO_URI=mongodb://localhost:27017/paper5
JWT_SECRET=paper5_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
NODE_ENV=development

# Email (required for password reset & lead notifications)
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
ADMIN_EMAIL=admin@paper5.co

# Password reset
RESET_TOKEN_EXPIRE_MINUTES=15
CLIENT_URL=http://localhost:3000
