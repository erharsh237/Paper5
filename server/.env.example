PORT=5000
MONGO_URI=mongodb://localhost:27017/paper5
JWT_SECRET=replace_with_output_of_node_-e_console.log(require('crypto').randomBytes(64).toString('hex'))
JWT_EXPIRE=7d
NODE_ENV=development

# Email (required for password reset & lead notifications)
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
ADMIN_EMAIL=admin@paper5.co

# Password reset
RESET_TOKEN_EXPIRE_MINUTES=15
CLIENT_URL=http://localhost:3000

# Chatbot (local Ollama — run `ollama serve` and `ollama pull llama3.1:8b` first)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
